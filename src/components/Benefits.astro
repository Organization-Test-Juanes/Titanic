---
const benefits = [
  { title: 'Equipos certificados', icon: 'M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { title: 'Garantía extendida', icon: 'M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z' },
  { title: 'Técnicos especializados', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM4 21v-2a6 6 0 0112 0v2' },
  { title: 'Cobertura nacional', icon: 'M12 2a10 10 0 110 20 10 10 0 010-20zM2 12h20M12 2c2.5 2.7 4 6.2 4 10s-1.5 7.3-4 10c-2.5-2.7-4-6.2-4-10s1.5-7.3 4-10z' },
  { title: 'Atención rápida', icon: 'M13 2L3 14h7l-1 8 10-12h-7z' },
  { title: 'Disponibilidad inmediata', icon: 'M12 8v4l3 3M12 2a10 10 0 110 20 10 10 0 010-20z' },
];
---

<section class="py-20 bg-ink relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-1.5 hazard-stripe"></div>
  <div class="mx-auto max-w-content px-6 lg:px-10">
    <div data-animate="up" data-animate-stagger="0.08" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-10">
      {benefits.map((b) => (
        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-sm bg-white/10 flex items-center justify-center flex-shrink-0">
            <svg viewBox="0 0 24 24" fill="none" stroke="#FFC600" stroke-width="1.8" class="w-5 h-5">
              <path d={b.icon} stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <p class="text-white font-body font-medium">{b.title}</p>
        </div>
      ))}
    </div>
  </div>
</section>
