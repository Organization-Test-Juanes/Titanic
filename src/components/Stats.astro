<section class="py-24 bg-mist">
  <div class="mx-auto max-w-content px-6 lg:px-10">
    <div data-animate="up" class="max-w-xl mb-14">
      <p class="section-eyebrow mb-3">Resultados que respaldan la operación</p>
      <h2 class="text-3xl lg:text-4xl text-ink">Cifras de una flota en movimiento constante</h2>
      <div class="fork-divider mt-5"><span></span><span></span></div>
    </div>

    <div data-animate="up" data-animate-stagger="0.1" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 items-end">
      <div class="bg-white rounded-md p-8 border border-white">
        <p data-counter="1200" data-counter-suffix="+" class="font-mono text-4xl text-blue">0</p>
        <p class="text-sm text-steel mt-2">Clientes atendidos</p>
      </div>
      <div class="bg-white rounded-md p-8 border border-white">
        <p data-counter="350" data-counter-suffix="+" class="font-mono text-4xl text-blue">0</p>
        <p class="text-sm text-steel mt-2">Equipos en flota</p>
      </div>
      <div class="bg-white rounded-md p-8 border border-white">
        <p data-counter="24" data-counter-suffix="/7" class="font-mono text-4xl text-blue">0</p>
        <p class="text-sm text-steel mt-2">Soporte técnico</p>
      </div>

      <div data-gauge="98" class="bg-ink rounded-md p-8 flex flex-col items-center">
        <svg viewBox="0 0 240 140" class="w-32">
          <path d="M20 120 A100 100 0 0 1 220 120" fill="none" stroke="#4A5568" stroke-width="10" stroke-linecap="round" />
          <circle cx="120" cy="120" r="6" fill="#FFC600" />
          <line data-gauge-needle x1="120" y1="120" x2="120" y2="40" stroke="#FFC600" stroke-width="5" stroke-linecap="round" />
        </svg>
        <p class="font-mono text-2xl text-white -mt-2">98%</p>
        <p class="text-sm text-white/70 mt-1">Satisfacción del cliente</p>
      </div>
    </div>
  </div>
</section>
