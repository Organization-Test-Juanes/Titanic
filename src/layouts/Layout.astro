---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TorqueLift — Venta, alquiler y mantenimiento de montacargas",
  description = "Montacargas certificados en venta y alquiler, con mantenimiento preventivo, correctivo y soporte técnico 24/7 en todo el país.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fuentes: tipografía display con herencia de letrero industrial,
         cuerpo técnico legible y monoespaciada para datos/specs -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Montacargas Titanic",
        description,
        telephone: "+57-300-000-0000",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Calle 80 # 45-12",
          addressLocality: "Bogotá",
          addressCountry: "CO",
        },
        openingHours: "Mo-Fr 07:00-18:00, Sa 08:00-13:00",
        areaServed: "CO",
      })}
    />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { initAll } from "../scripts/animations";
      initAll();
    </script>
  </body>
</html>
